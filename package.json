{
  "name": "3d-website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "queue:work": "node ace queue:work",
    "queue:work:ai": "node ace queue:work --queue=ai",
    "test": "node ace test",
    "test:db:up": "docker compose --profile test up -d postgres_test --wait",
    "test:db:down": "docker compose --profile test down postgres_test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -b && vue-tsc --noEmit --project inertia/tsconfig.json",
    "test:inertia": "vitest run",
    "prepare": "husky"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#jobs/*": "./app/jobs/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#shared/*": "./shared/*.js",
    "#config/*": "./config/*.js",
    "#utils/*": "./app/utils/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@fontsource/sora": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@japa/api-client": "^3.2.1",
    "@japa/assert": "^4.2.0",
    "@japa/browser-client": "^2.3.0",
    "@japa/plugin-adonisjs": "^5.2.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "~25.6.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/server-renderer": "^3.5.38",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "happy-dom": "^20.10.3",
    "hot-hook": "^1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.5",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.1.0",
    "@adonisjs/bouncer": "^4.0.0",
    "@adonisjs/core": "^7.3.4",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/i18n": "^3.0.1",
    "@adonisjs/inertia": "^4.2.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lucid": "^22.4.2",
    "@adonisjs/mail": "^10.3.0",
    "@adonisjs/queue": "^0.6.1",
    "@adonisjs/session": "^8.1.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.1",
    "@fontsource/instrument-serif": "^5.2.8",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@inertiajs/vue3": "^2.3.26",
    "@mistralai/mistralai": "^2.2.5",
    "@tuyau/core": "^1.2.2",
    "@vinejs/vine": "^4.4.0",
    "@vueuse/core": "^14.3.0",
    "cloudinary": "^2.10.0",
    "edge.js": "^6.5.1",
    "luxon": "^3.7.2",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "stripe": "^22.2.1",
    "vue": "^3.5.38",
    "vue-sonner": "^2.0.9"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config",
  "lint-staged": {
    "*.{ts,js,vue,json,css,edge,md}": "prettier --write"
  }
}
