<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title inertia>
      AdonisJS
    </title>

    <meta
      name="description"
      content="Fleet AI helps organizations track boats, equipment, and maintenance with intelligent signals."
    />
    <meta property="og:site_name" content="Fleet AI" />
    <meta property="og:type" content="website" />
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "FleetAi",
      "url": "https://fleetai.app",
      "logo": "https://fleetai.app/favicon.svg",
      "description": "Fleet maintenance platform for maritime teams",
      "sameAs": []
    }
    </script>

    @vite(['inertia/app.ts'])
    @inertiaHead()
    @stack('dumper')
  </head>

  <body>
    @inertia()
  </body>

</html>
